<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ (API 31) data extraction rules. Excludes sensitive
    SharedPreferences from both cloud backup and device-to-device
    transfer to keep on-device protection state truly local.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="anti_uninstall.xml" />
        <exclude domain="sharedpref" path="premium_status.xml" />
        <exclude domain="sharedpref" path="compassionate_access.xml" />
        <exclude domain="sharedpref" path="app_guard.xml" />
        <exclude domain="sharedpref" path="smart_features.xml" />
        <exclude domain="sharedpref" path="app_blocker.xml" />
        <exclude domain="sharedpref" path="view_blocker.xml" />
        <exclude domain="sharedpref" path="reel_blocker.xml" />
        <exclude domain="sharedpref" path="focus_mode.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="anti_uninstall.xml" />
        <exclude domain="sharedpref" path="premium_status.xml" />
        <exclude domain="sharedpref" path="compassionate_access.xml" />
        <exclude domain="sharedpref" path="app_guard.xml" />
        <exclude domain="sharedpref" path="smart_features.xml" />
    </device-transfer>
</data-extraction-rules>
